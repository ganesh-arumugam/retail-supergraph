{
  "name": "Apollo Router — Retail Supergraph",
  "type": "dashboard",
  "version": 21,
  "content": {
    "version": 21,
    "variables": [],
    "tiles": {
      "0": {
        "type": "markdown",
        "title": "",
        "markdown": "## Apollo Router — Retail Supergraph\n\nFederated GraphQL gateway across **8 subgraphs**: checkout · discovery · inventory · orders · products · reviews · shipping · users.  \nTelemetry via **OpenTelemetry → Dynatrace** (OTLP gRPC).  \n[Distributed Traces](https://zer60233.apps.dynatrace.com/ui/apps/dynatrace.distributedtracing)",
        "bounds": { "top": 0, "left": 0, "width": 20, "height": 2 }
      },
      "1": {
        "type": "query",
        "title": "Request Count",
        "query": "timeseries sum(apollo.router.operations)",
        "visualization": "SINGLE_VALUE",
        "visualizationSettings": {},
        "bounds": { "top": 2, "left": 0, "width": 5, "height": 4 }
      },
      "2": {
        "type": "query",
        "title": "p95 Router Latency",
        "query": "timeseries percentile(http.server.request.duration, 95)",
        "visualization": "SINGLE_VALUE",
        "visualizationSettings": {},
        "bounds": { "top": 2, "left": 5, "width": 5, "height": 4 }
      },
      "3": {
        "type": "query",
        "title": "Active Requests",
        "query": "timeseries avg(http.server.active_requests)",
        "visualization": "SINGLE_VALUE",
        "visualizationSettings": {},
        "bounds": { "top": 2, "left": 10, "width": 5, "height": 4 }
      },
      "4": {
        "type": "query",
        "title": "Response Cache Hits",
        "query": "timeseries sum(apollo.router.response.cache)",
        "visualization": "SINGLE_VALUE",
        "visualizationSettings": {},
        "bounds": { "top": 2, "left": 15, "width": 5, "height": 4 }
      },
      "5": {
        "type": "query",
        "title": "Request Rate by Operation Type",
        "query": "timeseries sum(apollo.router.operations), by:{graphql.operation.type}",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 6, "left": 0, "width": 10, "height": 8 }
      },
      "6": {
        "type": "query",
        "title": "p95 Latency by Operation",
        "query": "timeseries percentile(http.server.request.duration, 95), by:{graphql.operation.name}",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 6, "left": 10, "width": 10, "height": 8 }
      },
      "7": {
        "type": "query",
        "title": "Subgraph p95 Latency",
        "query": "timeseries percentile(http.client.request.duration, 95), by:{subgraph.name}",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 14, "left": 0, "width": 10, "height": 8 }
      },
      "8": {
        "type": "query",
        "title": "Response Cache by Subgraph",
        "query": "timeseries sum(apollo.router.response.cache), by:{subgraph.name}",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 14, "left": 10, "width": 10, "height": 8 }
      },
      "9": {
        "type": "query",
        "title": "Cache Hit Latency (p95)",
        "query": "timeseries percentile(apollo.router.cache.hit.time, 95)",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 22, "left": 0, "width": 10, "height": 8 }
      },
      "10": {
        "type": "query",
        "title": "Open Connections",
        "query": "timeseries sum(apollo.router.open_connections), by:{http.connection.state}",
        "visualization": "LINE_CHART",
        "visualizationSettings": {},
        "bounds": { "top": 22, "left": 10, "width": 10, "height": 8 }
      }
    },
    "layouts": [
      { "tileName": "0",  "bounds": { "top": 0,  "left": 0,  "width": 20, "height": 2 } },
      { "tileName": "1",  "bounds": { "top": 2,  "left": 0,  "width": 5,  "height": 4 } },
      { "tileName": "2",  "bounds": { "top": 2,  "left": 5,  "width": 5,  "height": 4 } },
      { "tileName": "3",  "bounds": { "top": 2,  "left": 10, "width": 5,  "height": 4 } },
      { "tileName": "4",  "bounds": { "top": 2,  "left": 15, "width": 5,  "height": 4 } },
      { "tileName": "5",  "bounds": { "top": 6,  "left": 0,  "width": 10, "height": 8 } },
      { "tileName": "6",  "bounds": { "top": 6,  "left": 10, "width": 10, "height": 8 } },
      { "tileName": "7",  "bounds": { "top": 14, "left": 0,  "width": 10, "height": 8 } },
      { "tileName": "8",  "bounds": { "top": 14, "left": 10, "width": 10, "height": 8 } },
      { "tileName": "9",  "bounds": { "top": 22, "left": 0,  "width": 10, "height": 8 } },
      { "tileName": "10", "bounds": { "top": 22, "left": 10, "width": 10, "height": 8 } }
    ]
  }
